{
  "manifest_version": 3,
  "name": "Manga-Pdf-Maker",
  "version": "1.0.0",
  "description": "Create PDFs from manga chapters",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "declarativeNetRequest",
    "cookies"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "referer_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "index.css",
        "index.js",
        "lib/jspdf.umd.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
